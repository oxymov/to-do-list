    def _add_combo(self, p, l, v, d):
        fr = ctk.CTkFrame(p); fr.pack(fill="x", pady=5); ctk.CTkLabel(fr, text=l+":", width=80).pack(side="left")
        cb = ctk.CTkComboBox(fr, values=v, width=300); cb.pack(side="left"); cb.set(d); self.widgets_manual[l]=cb

    def valider_edition(self, uuid_exist=None):
        new = {"uuid": uuid_exist if uuid_exist else str(uuid.uuid4())}
        new["Fichier"] = self.widgets_manual["Fichier"].get(); new["Filter"] = self.widgets_manual["Filter"].get(); new["Input"] = self.widgets_manual["Input"].get()
        new["Span"] = self.widgets_manual["Span"].get()
        for col in [c for c in COLONNES_A_AFFICHER if "Derive" not in c]:
            v = self.widgets_manual[col].get(); new[col] = v if v != "" else "0.0"
        new, tag = self.calculer_champs(new); new["tag"] = tag
        if uuid_exist:
            for i, r in enumerate(self.db_lignes):
                if r["uuid"] == uuid_exist: self.db_lignes[i] = new; break
        else: self.db_lignes.append(new); self.fichiers_visibles_set.add(new["Fichier"])
        self.top_manual.destroy(); self.appliquer_filtres_visuels(None); self.verifier_integrite_inputs(); self.calculer_et_afficher_incertitudes(); self.calculer_et_afficher_gauss(); self.update_combos_fichiers()

    def update_combos_fichiers(self):
        f = list(set([r["Fichier"] for r in self.db_lignes]))
        self.cb_file.configure(values=["Tous les fichiers"] + sorted(f))

    def choisir_fichiers(self):
        fs = filedialog.askopenfilenames(filetypes=[("PDF", "*.pdf")])
        if fs: self.fichiers_selectionnes = fs; [self.fichiers_visibles_set.add(os.path.basename(f)) for f in fs]

    def lancer_thread(self):
        if self.fichiers_selectionnes:
            self.btn_run.configure(state="disabled"); self.progress.pack(fill="x"); threading.Thread(target=self.process, daemon=True).start()
        else: self.verifier_integrite_inputs(); self.calculer_et_afficher_incertitudes(); self.calculer_et_afficher_gauss()

    def process(self):
        total = len(self.fichiers_selectionnes)
        self.db_lignes = [] 
        
        for idx, fpath in enumerate(self.fichiers_selectionnes):
            fname = os.path.basename(fpath)
            temp_buffer = {} 
            c_filt, c_inp = "?", "?" # FIX INPUT 4 & 8 : On garde en mémoire d'une page à l'autre !
            
            try:
                with pdfplumber.open(fpath) as pdf:
                    for page in pdf.pages:
                        text = page.extract_text(layout=True); 
                        if not text: continue
                        lines = text.split('\n')
                        
                        for line in lines:
                            line = line.strip()
                            if not line: continue
                            
                            # Recherche robuste (si décalage sur la même ligne)
                            match_f = re.search(r'Filter\s*:\s*([^:\n]+)', line)
                            if match_f:
                                extracted_filt = match_f.group(1).split("Input")[0].strip()
                                if extracted_filt: c_filt = extracted_filt
                            
                            match_i = re.search(r'Input\s*:\s*(\d+)', line)
                            if match_i: c_inp = match_i.group(1)
                            
                            if not any(t in c_filt.upper() for t in FILTRES_CIBLES): continue
                            
                            match_10 = re.search(r'^\s*10[,.]0(\s|$)', line)
                            match_2 = re.search(r'^\s*2[,.]0(\s|$)', line)
                            
                            if match_10 or match_2:
                                span_k = "10.0" if match_10 else "2.0"
                                parts = line.split(); key = (fname, c_filt, c_inp)
                                if key not in temp_buffer: temp_buffer[key] = {"10.0": {}, "2.0": {}}
                                
                                nb = len(parts)
                                if 3 <= nb <= 5:
                                    if len(parts) > 1: temp_buffer[key][span_k]["IEPE Comp"] = parts[1]
                                    if len(parts) > 2: temp_buffer[key][span_k]["IEPE Exc"] = parts[2]
                                    if len(parts) > 3: temp_buffer[key][span_k]["IEPE Gain"] = parts[3]
                                elif nb >= 8:
                                    m = {1:"Offset", 2:"DCGain", 3:"SINL", 4:"MSE", 5:"BWdth", 6:"CMRR", 7:"Noise", 8:"ACCpl"}
                                    for i, n in m.items():
                                        if i < len(parts): temp_buffer[key][span_k][n] = parts[i]
            except Exception as e: print(f"Erreur PDF {fname}: {e}")
            
            for key, spans in temp_buffer.items():
                d10 = spans.get("10.0", {})
                d2 = spans.get("2.0", {})
                
                dcgain_10 = str(d10.get("DCGain", ""))
                mse_10 = str(d10.get("MSE", ""))
                is_na = (not dcgain_10 or not mse_10 or "NA" in dcgain_10.upper() or "NA" in mse_10.upper())
                
                if is_na and d2:
                    row_data = d2.copy()
                    row_data["Span"] = "2.0" 
                    for iepe_k in ["IEPE Comp", "IEPE Exc", "IEPE Gain"]:
                        if iepe_k in d10: row_data[iepe_k] = d10[iepe_k]
                else:
                    row_data = d10.copy()
                    row_data["Span"] = "10.0" 
                    
                if not row_data: continue
                
                row_data["Fichier"] = key[0]; row_data["Filter"] = key[1]; row_data["Input"] = key[2]
                row_data["uuid"] = str(uuid.uuid4())
                row_c, tag = self.calculer_champs(row_data); row_c["tag"] = tag; self.db_lignes.append(row_c)
                
            self.after(0, self.progress.set, (idx+1)/total)
        self.after(0, self.finish)

    def finish(self):
        self.btn_run.configure(state="normal"); self.progress.pack_forget(); self.update_combos_fichiers()
        # Mise à jour de l'interface en lot (Évite la saturation !)
        self.appliquer_filtres_visuels(None) 
        self.after(500, lambda: [self.verifier_integrite_inputs(), self.calculer_et_afficher_incertitudes(), self.calculer_et_afficher_gauss()])

