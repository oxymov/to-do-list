        e_com = ctk.CTkEntry(fr_c, width=280); e_com.pack(side="left")

        def valider_export():
            file_path = filedialog.asksaveasfilename(defaultextension=".json", filetypes=[("Fichier JSON", "*.json")])
            if file_path:
                derives_export = []
                tols_operet = self.regles_actives.get("OPERET", DEFAUT_TOLERANCES_OPERET)
                
                for row in self.db_lignes:
                    filt_name = str(row.get("Filter", "")).upper()
                    if "BESSEL" in filt_name: filt_key = "BESSEL"
                    elif "BUTTERWORTH" in filt_name: filt_key = "BUTTERWORTH"
                    else: filt_key = "WIDEBAND"

                    inp = row.get("Input", "?")
                    
                    # Tension
                    if filt_key in ["BESSEL", "BUTTERWORTH"]:
                        t_tols = tols_operet[filt_key]["TENSION"]
                        g_ten = self.parse_float(row.get("DCGain"))
                        e_ten = self.parse_float(row.get("MSE"))
                        im_ten = 2 * math.sqrt(g_ten**2 + e_ten**2)
                        
                        if abs(g_ten) > t_tols["Gain"]: derives_export.append(f"Input {inp} [{filt_key}] - TENSION Gain : {g_ten:.4f}% > Tol: {t_tols['Gain']}%")
                        if abs(e_ten) > t_tols["MSE"]: derives_export.append(f"Input {inp} [{filt_key}] - TENSION MSE : {e_ten:.4f}% > Tol: {t_tols['MSE']}%")
                        if im_ten > t_tols["Ig"]: derives_export.append(f"Input {inp} [{filt_key}] - TENSION I/M : {im_ten:.4f}% > Tol: {t_tols['Ig']}%")
                    
                    # IEPE uniquement pour WIDEBAND
                    if filt_key == "WIDEBAND":
                        i_tols = tols_operet[filt_key]["IEPE"]
                        g_iepe = self.parse_float(row.get("IEPE Gain"))
                        e_iepe_mse = self.parse_float(row.get("MSE")) 
                        im_iepe = 2 * math.sqrt(g_iepe**2 + e_iepe_mse**2)
                        
                        if abs(g_iepe) > i_tols["Gain"]: derives_export.append(f"Input {inp} [WIDEBAND] - IEPE Gain : {g_iepe:.4f}% > Tol: {i_tols['Gain']}%")
                        if abs(e_iepe_mse) > i_tols["MSE"]: derives_export.append(f"Input {inp} [WIDEBAND] - IEPE MSE : {e_iepe_mse:.4f}% > Tol: {i_tols['MSE']}%")
                        if im_iepe > i_tols["Ig"]: derives_export.append(f"Input {inp} [WIDEBAND] - IEPE I/M : {im_iepe:.4f}% > Tol: {i_tols['Ig']}%")
                
                export_data = {
                    "metadata": {
                        "date_export": datetime.now().strftime("%d/%m/%Y %H:%M"),
                        "materiel": e_mat.get(),
                        "annee": e_annee.get(),
                        "date_mesure": e_date.get(),
                        "nom": e_nom.get(),
                        "commentaire": e_com.get()
                    },
                    "bilan_conformite": {
                        "statut_global": "HORS TOLERANCE" if derives_export else "CONFORME (OK)",
                        "nombre_defauts": len(derives_export),
                        "liste_defauts": derives_export
                    },
                    "tolerances": self.regles_actives,
                    "data": self.db_lignes
                }
                
                try:
                    with open(file_path, 'w', encoding='utf-8') as f:
                        json.dump(export_data, f, indent=4, ensure_ascii=False)
                    messagebox.showinfo("Succès", "Données exportées avec succès !")
                    top_ex.destroy()
                except Exception as e:
                    messagebox.showerror("Erreur", f"Erreur lors de l'export : {e}")

        ctk.CTkButton(top_ex, text="Valider & Enregistrer", command=valider_export, fg_color="#27AE60", height=40).pack(pady=30)

