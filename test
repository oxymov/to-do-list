    def charger_config(self):
        config = REGLES_DEFAUT.copy()
        if "OPERET" not in config: config["OPERET"] = DEFAUT_TOLERANCES_OPERET
        if "WIDEBAND" not in config.get("OPERET", {}):
            config["OPERET"]["WIDEBAND"] = DEFAUT_TOLERANCES_OPERET["WIDEBAND"]

        if os.path.exists(FICHIER_CONFIG):
            try:
                with open(FICHIER_CONFIG, 'r') as f:
                    loaded = json.load(f)
                    for k, v in loaded.items(): config[k] = v
                    if "WIDEBAND" not in config["OPERET"]:
                        config["OPERET"]["WIDEBAND"] = DEFAUT_TOLERANCES_OPERET["WIDEBAND"]
            except: pass
        return config

    def sauvegarder_params(self):
        try:
            nouvelles = {}
            for k, w in self.entries_params.items():
                if k == "Nb_Inputs_Max":
                    val = float(w['min'].get())
                    nouvelles[k] = [val, val]
                else:
                    nouvelles[k] = [float(w['min'].get().replace(',', '.')), float(w['max'].get().replace(',', '.'))]
            
            nouvelles["OPERET"] = {}
            for filt in ["BESSEL", "BUTTERWORTH", "WIDEBAND"]:
                nouvelles["OPERET"][filt] = {}
                for mode in ["TENSION", "IEPE"]:
                    nouvelles["OPERET"][filt][mode] = {}
                    for param in ["Gain", "MSE", "Ig"]:
                        val_str = self.entries_operet[filt][mode][param].get()
                        nouvelles["OPERET"][filt][mode][param] = float(val_str.replace(',', '.'))

            self.regles_actives = nouvelles
            with open(FICHIER_CONFIG, 'w') as f: json.dump(nouvelles, f, indent=4)
            self.recalculer_tout_db()
            messagebox.showinfo("Succès", "Configuration sauvegardée !")
        except Exception as e: messagebox.showerror("Erreur", f"Erreur : {e}")

