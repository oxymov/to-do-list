    def ouvrir_comparateur_delta(self):
        filepaths = filedialog.askopenfilenames(title="Sélectionnez EXACTEMENT 2 fichiers d'export JSON", filetypes=[("Fichier QualiData JSON", "*.json")])
        if len(filepaths) != 2:
            messagebox.showwarning("Attention", "Veuillez sélectionner exactement 2 fichiers JSON pour calculer la différence.")
            return
        
        try:
            with open(filepaths[0], 'r', encoding='utf-8') as f1, open(filepaths[1], 'r', encoding='utf-8') as f2:
                d1 = json.load(f1)
                d2 = json.load(f2)
        except Exception as e:
            messagebox.showerror("Erreur", f"Impossible de lire les fichiers : {e}")
            return
        
        def build_dict(data_list):
            res = {}
            for r in data_list:
                res[(str(r.get("Filter", "")).upper(), str(r.get("Input", "")))] = r
            return res
            
        map1 = build_dict(d1.get("data", []))
        map2 = build_dict(d2.get("data", []))
        all_keys = set(map1.keys()).union(set(map2.keys()))
        
        top_delta = ctk.CTkToplevel(self)
        top_delta.title("Comparaison des Dérives (Ajustement)")
        top_delta.geometry("1100x600")
        top_delta.attributes("-topmost", True)
        
        name1 = f"{d1.get('metadata', {}).get('annee', 'Fichier 1')} - {d1.get('metadata', {}).get('date_mesure', '')}"
        name2 = f"{d2.get('metadata', {}).get('annee', 'Fichier 2')} - {d2.get('metadata', {}).get('date_mesure', '')}"
        
        ctk.CTkLabel(top_delta, text=f"Comparatif Direct : {name1} VS {name2}", font=("Arial", 16, "bold"), text_color="#0033A0").pack(pady=10)
        ctk.CTkLabel(top_delta, text="Lecture : Une évolution Verte signifie que l'erreur se rapproche de 0 (Amélioration). Rouge signifie que l'erreur s'éloigne (Dégradation).").pack()
        
        tv_fr = ctk.CTkFrame(top_delta)
        tv_fr.pack(fill="both", expand=True, padx=10, pady=10)
        
        tv = ttk.Treeview(tv_fr, columns=["Filtre", "Inp", "Param", "Val1", "Val2", "Delta"], show="headings", height=20)
        tv.heading("Filtre", text="Filtre"); tv.column("Filtre", width=180, anchor="center")
        tv.heading("Inp", text="Input"); tv.column("Inp", width=50, anchor="center")
        tv.heading("Param", text="Paramètre"); tv.column("Param", width=150, anchor="center")
        tv.heading("Val1", text=f"[{name1}]"); tv.column("Val1", width=120, anchor="center")
        tv.heading("Val2", text=f"[{name2}]"); tv.column("Val2", width=120, anchor="center")
        tv.heading("Delta", text="Évolution (V2 - V1)"); tv.column("Delta", width=150, anchor="center")
        
        tv.tag_configure("green", foreground="#196F3D", font=("Arial", 10, "bold"))
        tv.tag_configure("red", foreground="#C0392B", font=("Arial", 10, "bold"))
        tv.tag_configure("neutral", foreground="black")
        
        vsb = ttk.Scrollbar(tv_fr, orient="vertical", command=tv.yview)
        tv.configure(yscrollcommand=vsb.set)
        tv.pack(side="left", fill="both", expand=True)
        vsb.pack(side="right", fill="y")
        
        for key in sorted(all_keys):
            r1 = map1.get(key, {})
            r2 = map2.get(key, {})
            
            params_to_check = [
                ("Tension Gain", "DCGain"), 
                ("Tension MSE", "MSE"), 
                ("IEPE Gain", "IEPE Gain"),
                ("IEPE MSE", "MSE") 
            ]
            
            for p_label, p_key in params_to_check:
                if "IEPE" in p_label and "WIDEBAND" not in key[0]:
                    continue
                if "Tension" in p_label and "WIDEBAND" in key[0]:
                    continue
                    
                v1_str = r1.get(p_key, "N/A")
                v2_str = r2.get(p_key, "N/A")
                
                try: val1 = float(str(v1_str).replace(',', '.').replace('⚠️ ', ''))
                except: val1 = None
                try: val2 = float(str(v2_str).replace(',', '.').replace('⚠️ ', ''))
                except: val2 = None
                
                if val1 is not None and val2 is not None:
                    delta = val2 - val1
                    delta_str = f"{delta:+.4f}%"
                    
                    if abs(val2) < abs(val1): tag = "green"  
                    elif abs(val2) > abs(val1): tag = "red"  
                    else: tag = "neutral"
                    
                    tv.insert("", "end", values=(key[0], key[1], p_label, f"{val1:.4f}%", f"{val2:.4f}%", delta_str), tags=(tag,))
                elif val1 is not None or val2 is not None:
                    tv.insert("", "end", values=(key[0], key[1], p_label, v1_str, v2_str, "Incomplet"), tags=("neutral",))

