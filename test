        self._add_combo(main, "Fichier", sorted(files), row.get("Fichier", "MANUEL") if row else "MANUEL")
        self._add_combo(main, "Filter", LISTE_FILTRES, row.get("Filter", LISTE_FILTRES[0]) if row else LISTE_FILTRES[0])
        fr = ctk.CTkFrame(main); fr.pack(fill="x", pady=5); ctk.CTkLabel(fr, text="Input:", width=80).pack(side="left")
        e = ctk.CTkEntry(fr); e.pack(side="left", fill="x", expand=True); e.insert(0, str(row.get("Input", ""))) if row else None; self.widgets_manual["Input"]=e
        fr_span = ctk.CTkFrame(main); fr_span.pack(fill="x", pady=5); ctk.CTkLabel(fr_span, text="Span:", width=80).pack(side="left")
        e_span = ctk.CTkEntry(fr_span); e_span.pack(side="left", fill="x", expand=True); e_span.insert(0, str(row.get("Span", "10.0")) if row else "10.0"); self.widgets_manual["Span"]=e_span
        for col in [c for c in COLONNES_A_AFFICHER if "Derive" not in c]:
