                im_iepe = 2 * math.sqrt(g_iepe**2 + e_iepe**2)
                
                p_gi = (abs(g_iepe) / i_tols["Gain"]) * 100 if i_tols["Gain"] else 0
                p_ei = (abs(e_iepe) / i_tols["MSE"]) * 100 if i_tols["MSE"] else 0
                p_imi = (im_iepe / i_tols["Ig"]) * 100 if i_tols["Ig"] else 0

                if p_gi > 1.0: derives.append((p_gi, inp, "IEPE", "Gain", f"{g_iepe:.4f}", f"{p_gi:.1f}%"))
                if p_ei > 1.0: derives.append((p_ei, inp, "IEPE", "MSE", f"{e_iepe:.4f}", f"{p_ei:.1f}%"))
                if p_imi > 1.0: derives.append((p_imi, inp, "IEPE", "I/M", f"{im_iepe:.4f}", f"{p_imi:.1f}%"))

