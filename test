    def charger_fichier_comparaison(self):
        filepaths = filedialog.askopenfilenames(filetypes=[("Fichier QualiData JSON", "*.json")])
        if not filepaths: return

        for path in filepaths:
            try:
                with open(path, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                
                if "metadata" not in data or "data" not in data:
                    messagebox.showerror("Erreur", f"Le fichier {os.path.basename(path)} n'est pas un export valide.")
                    continue
                
                self.creer_carte_comparaison(data, os.path.basename(path))
            except Exception as e:
                messagebox.showerror("Erreur", f"Impossible de lire {os.path.basename(path)} : {e}")

    def creer_carte_comparaison(self, data, filename):
        meta = data.get("metadata", {})
        tols = data.get("tolerances", {})
        lignes = data.get("data", [])

        derives = []
        tols_operet = tols.get("OPERET", DEFAUT_TOLERANCES_OPERET)

        for row in lignes:
            filt_name = str(row.get("Filter", "")).upper()
            if "BESSEL" in filt_name: filt_key = "BESSEL"
            elif "BUTTERWORTH" in filt_name: filt_key = "BUTTERWORTH"
            else: filt_key = "WIDEBAND"
            
            inp = row.get("Input", "?")
            
            if filt_key in ["BESSEL", "BUTTERWORTH"]:
                t_tols = tols_operet[filt_key]["TENSION"]
                g_ten = float(str(row.get("DCGain", 0)).replace(',', '.').replace('⚠️ ', ''))
                e_ten = float(str(row.get("MSE", 0)).replace(',', '.').replace('⚠️ ', ''))
                im_ten = 2 * math.sqrt(g_ten**2 + e_ten**2)
                
                p_gt = (abs(g_ten) / t_tols["Gain"]) * 100 if t_tols["Gain"] else 0
                p_et = (abs(e_ten) / t_tols["MSE"]) * 100 if t_tols["MSE"] else 0
                p_imt = (im_ten / t_tols["Ig"]) * 100 if t_tols["Ig"] else 0
                
                if p_gt > 1.0: derives.append((p_gt, inp, "Tension", "Gain", f"{g_ten:.4f}", f"{p_gt:.1f}%"))
                if p_et > 1.0: derives.append((p_et, inp, "Tension", "MSE", f"{e_ten:.4f}", f"{p_et:.1f}%"))
                if p_imt > 1.0: derives.append((p_imt, inp, "Tension", "I/M", f"{im_ten:.4f}", f"{p_imt:.1f}%"))

            if filt_key == "WIDEBAND":
                i_tols = tols_operet[filt_key]["IEPE"]
                g_iepe = float(str(row.get("IEPE Gain", 0)).replace(',', '.').replace('⚠️ ', ''))
