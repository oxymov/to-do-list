    def calculer_et_afficher_gauss(self):
        self.tree_gauss.delete(*self.tree_gauss.get_children())
        TOLS = self.regles_actives.get("OPERET", DEFAUT_TOLERANCES_OPERET)
        params = ["Tension Gain", "Tension MSE", "Tension I/M", "IEPE Gain", "IEPE MSE", "IEPE I/M"]
        bins = {p: [0]*17 for p in params}
        self.gauss_details = {p: {i: [] for i in range(17)} for p in params}
        
        def get_bin_index(pct):
            if pct < -100: return 0
            elif pct < -45: return 1
            elif pct < -25: return 2
            elif pct < -20: return 3
            elif pct < -15: return 4
            elif pct < -10: return 5
            elif pct < -5: return 6
            elif pct < -1: return 7
            elif pct <= 1: return 8
            elif pct <= 5: return 9
            elif pct <= 10: return 10
            elif pct <= 15: return 11
            elif pct <= 20: return 12
            elif pct <= 25: return 13
            elif pct <= 45: return 14
            elif pct <= 100: return 15
            else: return 16

        for row in self.db_lignes:
            if self.fichiers_visibles_set and row["Fichier"] not in self.fichiers_visibles_set: continue
            
            filt_name = str(row["Filter"]).upper()
            if "BESSEL" in filt_name: filt_key = "BESSEL"
            elif "BUTTERWORTH" in filt_name: filt_key = "BUTTERWORTH"
            else: filt_key = "WIDEBAND"
            
            f_name = row['Fichier']
            if len(f_name) > 18: f_name = f_name[:15] + "..."
            short_filt = "BESSEL" if "BESSEL" in filt_key else "BUTTER" if "BUTTER" in filt_key else "WIDE"
            inp = row.get('Input', '?')

            if filt_key in ["BESSEL", "BUTTERWORTH"]:
                tols_t = TOLS[filt_key]["TENSION"]
                g_t = self.parse_float(row.get("DCGain"))
                e_t = self.parse_float(row.get("MSE"))
                im_t = 2 * math.sqrt(g_t**2 + e_t**2)
                
                p_gt = (g_t / tols_t["Gain"]) * 100 if tols_t["Gain"] else 0
                p_et = (e_t / tols_t["MSE"]) * 100 if tols_t["MSE"] else 0
                p_imt = (im_t / tols_t["Ig"]) * 100 if tols_t["Ig"] else 0
                
                idx = get_bin_index(p_gt); bins["Tension Gain"][idx] += 1; self.gauss_details["Tension Gain"][idx].append(f"Inp {inp} | {short_filt} | {f_name} ➔ {g_t:.4f}%")
                idx = get_bin_index(p_et); bins["Tension MSE"][idx] += 1; self.gauss_details["Tension MSE"][idx].append(f"Inp {inp} | {short_filt} | {f_name} ➔ {e_t:.4f}%")
                idx = get_bin_index(p_imt); bins["Tension I/M"][idx] += 1; self.gauss_details["Tension I/M"][idx].append(f"Inp {inp} | {short_filt} | {f_name} ➔ {im_t:.4f}%")
            
            if filt_key == "WIDEBAND":
                tols_i = TOLS[filt_key]["IEPE"]
                g_i = self.parse_float(row.get("IEPE Gain"))
                e_i = self.parse_float(row.get("MSE")) 
                im_i = 2 * math.sqrt(g_i**2 + e_i**2)
                
                p_gi = (g_i / tols_i["Gain"]) * 100 if tols_i["Gain"] else 0
                p_ei = (e_i / tols_i["MSE"]) * 100 if tols_i["MSE"] else 0
                p_imi = (im_i / tols_i["Ig"]) * 100 if tols_i["Ig"] else 0
                
                idx = get_bin_index(p_gi); bins["IEPE Gain"][idx] += 1; self.gauss_details["IEPE Gain"][idx].append(f"Inp {inp} | {short_filt} | {f_name} ➔ {g_i:.4f}%")
                idx = get_bin_index(p_ei); bins["IEPE MSE"][idx] += 1; self.gauss_details["IEPE MSE"][idx].append(f"Inp {inp} | {short_filt} | {f_name} ➔ {e_i:.4f}%")
                idx = get_bin_index(p_imi); bins["IEPE I/M"][idx] += 1; self.gauss_details["IEPE I/M"][idx].append(f"Inp {inp} | {short_filt} | {f_name} ➔ {im_i:.4f}%")

        interval_labels = [
            "🟥 <-100%", "🟥 [-100 à -45[", "🟧 [-45 à -25[", "🟧 [-25 à -20[", 
            "🟧 [-20 à -15[", "🟧 [-15 à -10[", "🟧 [-10 à -5[", "🟧 [-5 à -1[", 
            "🟩 [-1 à 1]", 
            "🟧 ]1 à 5]", "🟧 ]5 à 10]", "🟧 ]10 à 15]", "🟧 ]15 à 20]", "🟧 ]20 à 25]", 
            "🟧 ]25 à 45]", "🟥 ]45 à 100]", "🟥 >100%"
        ]
        interval_tags = [
            "red", "red", "orange", "orange", "orange", "orange", "orange", "orange",
            "green",
            "orange", "orange", "orange", "orange", "orange", "orange", "red", "red"
        ]

        for i in range(17):
            row_vals = [interval_labels[i]]
            for p in params:
                val = bins[p][i]
                row_vals.append(str(val) if val > 0 else "-")
            self.tree_gauss.insert("", "end", values=row_vals, tags=(interval_tags[i],))

    # --------------------------------------------------------------------------
    # LOGIQUE INCERTITUDES
    # --------------------------------------------------------------------------
    def calculer_et_afficher_incertitudes(self):
        self.tree_ten.delete(*self.tree_ten.get_children())
        self.tree_iepe.delete(*self.tree_iepe.get_children())
        
        TOLS = self.regles_actives.get("OPERET", DEFAUT_TOLERANCES_OPERET)

        for row in self.db_lignes:
            if self.fichiers_visibles_set and row["Fichier"] not in self.fichiers_visibles_set: continue

            filt_name = str(row["Filter"]).upper()
            if "BESSEL" in filt_name: filt_key = "BESSEL"
            elif "BUTTERWORTH" in filt_name: filt_key = "BUTTERWORTH"
            else: filt_key = "WIDEBAND"
            
            if filt_key in ["BESSEL", "BUTTERWORTH"]:
                tols_ten = TOLS[filt_key]["TENSION"]
                g_ten = self.parse_float(row.get("DCGain"))
                e_ten = self.parse_float(row.get("MSE"))
                im_ten = 2 * math.sqrt(g_ten**2 + e_ten**2)
                
                fails_ten = []
                if abs(g_ten) > tols_ten["Gain"]: fails_ten.append("Gain")
                if abs(e_ten) > tols_ten["MSE"]: fails_ten.append("MSE")
                if im_ten > tols_ten["Ig"]: fails_ten.append("I/M")
                
                tag_t = "red" if fails_ten else "green"
                dec_t = f"NOK: {', '.join(fails_ten)}" if fails_ten else "OK"
                self.tree_ten.insert("", "end", values=(row["Fichier"], row["Filter"], row["Input"], f"{g_ten:.4f}", f"{e_ten:.4f}", f"{im_ten:.4f}", dec_t), tags=(tag_t,))

            if filt_key == "WIDEBAND":
                tols_iepe = TOLS[filt_key]["IEPE"]
                g_iepe = self.parse_float(row.get("IEPE Gain"))
                e_iepe_mse = self.parse_float(row.get("MSE")) 
                im_iepe = 2 * math.sqrt(g_iepe**2 + e_iepe_mse**2)
                
                fails_iepe = []
                if abs(g_iepe) > tols_iepe["Gain"]: fails_iepe.append("Gain")
                if abs(e_iepe_mse) > tols_iepe["MSE"]: fails_iepe.append("MSE")
                if im_iepe > tols_iepe["Ig"]: fails_iepe.append("I/M")
                
                tag_i = "red" if fails_iepe else "green"
                dec_i = f"NOK: {', '.join(fails_iepe)}" if fails_iepe else "OK"
                self.tree_iepe.insert("", "end", values=(row["Fichier"], row["Filter"], row["Input"], f"{g_iepe:.4f}", f"{e_iepe_mse:.4f}", f"{im_iepe:.4f}", dec_i), tags=(tag_i,))

    # --------------------------------------------------------------------------
    # LOGIQUES COMMUNES
    # --------------------------------------------------------------------------
    def parse_float(self, val):
        try: return float(str(val).replace(',', '.').replace('⚠️ ', ''))
        except: return 0.0

    def calculer_champs(self, row):
        try:
            v_cmrr = self.parse_float(row.get("CMRR"))
            err_cmrr = (10 ** (-abs(v_cmrr)/20)) * 100 if row.get("CMRR") and "NA" not in str(row.get("CMRR")) else 0.0
            rss = math.sqrt(self.parse_float(row.get("Offset"))**2 + self.parse_float(row.get("DCGain"))**2 + self.parse_float(row.get("MSE"))**2 + err_cmrr**2)
            row["Derive_Std"] = f"{rss:.3f}"
        except: row["Derive_Std"] = "0.000"
        try:
            v_comp = self.parse_float(row.get("IEPE Comp"))
            delta = abs(v_comp - 24.0) if v_comp > 1 else 0.0
            rss_iepe = math.sqrt(delta**2 + self.parse_float(row.get("IEPE Gain"))**2)
            row["Derive_IEPE"] = f"{rss_iepe:.3f}"
        except: row["Derive_IEPE"] = "0.000"
        is_error = False
        for k, v in row.items():
            if k in self.regles_actives and k not in ["Nb_Inputs_Max", "OPERET"]:
                val = self.parse_float(v)
                mini, maxi = self.regles_actives[k]
                clean = str(v).replace("⚠️ ", "")
                row[k] = clean
                if not (mini <= val <= maxi): is_error = True; row[k] = f"⚠️ {clean}"
        row["Etat"] = "Alerte" if is_error else "OK"
        return row, "error" if is_error else "ok"

    def recalculer_tout_db(self):
        for i, r in enumerate(self.db_lignes):
            new_r, tag = self.calculer_champs(r); new_r["tag"] = tag; self.db_lignes[i] = new_r
        self.appliquer_filtres_visuels(None); self.verifier_integrite_inputs(); self.calculer_et_afficher_incertitudes(); self.calculer_et_afficher_gauss()

    def reset_filters(self):
        self.var_filter_type.set("Tous les filtres")
        self.fichiers_visibles_set = set([r["Fichier"] for r in self.db_lignes] + ["MANUEL"] + [os.path.basename(f) for f in self.fichiers_selectionnes])
        self.appliquer_filtres_visuels(None)

    def ouvrir_selecteur_fichiers(self):
        tous_fichiers = sorted(list(set([r["Fichier"] for r in self.db_lignes] + ["MANUEL"] + [os.path.basename(f) for f in self.fichiers_selectionnes])))
        if not tous_fichiers: messagebox.showinfo("Info", "Aucun fichier."); return
        top = ctk.CTkToplevel(self); top.title("Filtrer"); top.geometry("400x600"); top.attributes("-topmost", True)
        scroll = ctk.CTkScrollableFrame(top); scroll.pack(fill="both", expand=True, padx=10)
        self.check_vars = {}
        for f in tous_fichiers:
            var = ctk.BooleanVar(value=(f in self.fichiers_visibles_set))
            ctk.CTkCheckBox(scroll, text=f, variable=var).pack(anchor="w", pady=2)
            self.check_vars[f] = var
        def valider():
            self.fichiers_visibles_set = set([n for n, v in self.check_vars.items() if v.get()])
            self.appliquer_filtres_visuels(None); self.calculer_et_afficher_incertitudes(); self.calculer_et_afficher_gauss()
            top.destroy()
        ctk.CTkButton(top, text="VALIDER", command=valider).pack(pady=10)

    def appliquer_filtres_visuels(self, event):
        self.tree.delete(*self.tree.get_children())
        f_type = self.var_filter_type.get()
        for row in self.db_lignes:
            if self.fichiers_visibles_set and row["Fichier"] not in self.fichiers_visibles_set: continue
            if f_type != "Tous les filtres" and row["Filter"] != f_type: continue
            vals = [row["uuid"]] + [row.get(c, "") for c in ["Fichier", "Filter", "Input", "Span", "Etat"] + COLONNES_A_AFFICHER]
            self.tree.insert("", "end", values=vals, tags=(row["tag"],))
        if event:
            self.calculer_et_afficher_incertitudes(); self.calculer_et_afficher_gauss()

    def verifier_integrite_inputs(self):
        self.tree_missing.delete(*self.tree_missing.get_children())
        target_max = int(self.regles_actives.get("Nb_Inputs_Max", [8.0])[0])
        data = {}
        for row in self.db_lignes:
            f, filt = row["Fichier"], row["Filter"]
            try: inp = int(re.search(r'(\d+)', str(row["Input"])).group(1))
            except: continue
            if f not in data: data[f] = {}
            if filt not in data[f]: data[f][filt] = []
            data[f][filt].append(inp)
        
        if not data: self.tree_missing.insert("", "end", values=("AUCUNE DONNÉE", "-", "-"), tags=("miss",)); return
        for f, filtres in data.items():
            for filt, inputs in filtres.items():
                missing = sorted(list(set(range(1, target_max + 1)) - set(inputs)))
                if missing: self.tree_missing.insert("", "end", values=(f, filt, f"MANQUE: {missing}"), tags=("miss",))
                else: self.tree_missing.insert("", "end", values=(f, filt, f"COMPLET (1-{target_max})"), tags=("good",))

    def supprimer_selection(self):
        sel = self.tree.selection()
        if not sel: return
        if not messagebox.askyesno("Confirmer", "Supprimer ?"): return
        uuid_target = self.tree.item(sel[0], 'values')[0]
        self.db_lignes = [r for r in self.db_lignes if r["uuid"] != uuid_target]
        self.appliquer_filtres_visuels(None); self.verifier_integrite_inputs(); self.calculer_et_afficher_incertitudes(); self.calculer_et_afficher_gauss(); self.update_combos_fichiers()

    def editer_selection(self):
        sel = self.tree.selection(); 
        if not sel: return
        uuid_target = self.tree.item(sel[0], 'values')[0]
        row = next((r for r in self.db_lignes if r["uuid"] == uuid_target), None)
