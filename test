            e = ctk.CTkEntry(fr); e.pack(side="right", fill="x", expand=True)
            e.insert(0, str(row.get(col, "0.0")).replace("⚠️ ", "") if row else "0.0"); self.widgets_manual[col]=e
        cmd = lambda: self.valider_edition(row["uuid"] if row else None)
